@model LoginModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Login";
}

@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger" role="alert" style="text-align:center">
        <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
        @TempData["MensagemErro"]
    </div>

}

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success" role="alert" style="text-align:center">
        <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
        @TempData["MensagemSucesso"]
    </div>

}

<form asp-action="Entrar" asp-controller="Login" method="post">
    <div class="container">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                <div class="card" style="border-radius: 1rem;">
                    <div class="card-body p-3 text-center">
                        <div class="mb-md-5 mt-md-4 pb-5">
                            <h2 class="fw-bold mb-2 text-uppercase">Login</h2>
                            <div class="form-outline form-white mb-4">
                                <input type="text" asp-for="Login" class="form-control form-control-lg" id="login" />
                                @Html.ValidationMessageFor(x => x.Login)
                                <br>
                            </div>
                            <div class="form-outline form-white mb-4">
                                <h2 class="fw-bold mb-2 text-uppercase">Senha</h2>
                                <input type="text" asp-for="Senha" type="password" id="typePasswordX" class="form-control form-control-lg" />
                                @Html.ValidationMessageFor(x => x.Senha)
                                <br>
                            </div>
                            <p class="small mb-5 pb-lg-4 font-w"><a asp-controller="Login" asp-action="RedefinirSenha">Esqueceu a senha?</a></p>
                            <button class="btn btn-outline-light btn-lg px-5" type="submit">Entrar</button>
                        </div>
                        <div>
                            <p class="mb-0">
                                Usuario-Administrador: Admin, senha:123456
                            </p>
                            <p>
                                Usuario-Padrao: fernando, senha:1234567
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>