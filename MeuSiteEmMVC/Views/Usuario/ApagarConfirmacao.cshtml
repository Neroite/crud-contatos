@model UsuarioModel
@{
    ViewData["Title"] = "Confirmação apagar o usuário";
}

<div class="text-center">

    <h3>Realmente deseja apagar o contato (@Model.Nome)?</h3>

</div>
<br><br>
<a class="btn btn-primary w-100" role="button" asp-controller="Usuario" asp-action="Index">Cancelar</a>
<br><br>
<a class="btn btn-danger w-100" role="button" asp-controller="Usuario" asp-action="Apagar" asp-route-id="@Model.Id" role="button">Confirmar exclusão</a>

