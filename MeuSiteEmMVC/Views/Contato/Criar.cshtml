@{
    ViewData["Title"] = "Criar Contato";
}

<div class="text-center">

    <h1 class="display-4">Cadastrar Contato</h1>

</div>

<form>

    <div class="mb-3">
        <label for="nome">Nome</label>
        <input type="text" class="form-control" placeholder="Digite o nome do contato">
    </div>

    <div class="mb-3">
        <label for="email">Email</label>
        <input type="email" class="form-control" placeholder="Digite o Email do contato">
    </div>

    <div class="mb-3">
        <label for="celular">Celular</label>
        <input type="text" class="form-control" placeholder="Digite o Celular do contato">
    </div>

    <button type="submit" class="btn btn-primary btn-lg btn-block">Adicionar</button>
    <a class="btn btn-secondary btn-lg btn-block" asp-controller="Contato" asp-action="Index" role="button">Voltar</a>

</form>
